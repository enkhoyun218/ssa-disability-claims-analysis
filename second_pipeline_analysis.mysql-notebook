    "content": "\\about\nUSE benefits_system;\nSELECT COUNT(*) FROM benefits_applications;\nSELECT * FROM benefits_applications LIMIT 20;\n\n#B1. How many total events are in the table?\nSELECT COUNT(*)\nFROM benefits_applications;\n\n#B2. What are all the unique stages in the pipeline?\nSELECT DISTINCT stage\nFROM benefits_applications;\n\n#B3. How many unique applications exist?\nSELECT COUNT(DISTINCT application_id)\nFROM benefits_applications;\n\n#B4. How many applications per applicant type — sorted highest to lowest?\nSELECT applicant_type, COUNT(DISTINCT application_id) as num_application\nFROM benefits_applications\nGROUP BY applicant_type \nORDER BY num_application DESC;\n\n#B5. Show all events for application_id = 1 ordered by entered_at.\nSELECT *\nFROM benefits_applications\nWHERE application_id = 1\nORDER BY entered_at ASC;\n\n#B6. How many applications were denied? (status = 'Denied')\nSELECT COUNT(DISTINCT application_id) as num_denied_app\nFROM benefits_applications\nWHERE status = 'Denied';\n\n#B7. How many Critical priority applications never reached 'Benefits Issued'?\nSELECT COUNT(DISTINCT application_id) as num_app\nFROM benefits_applications\nWHERE priority = 'Critical'\nAND application_id NOT IN (\nSELECT application_id\nFROM benefits_applications\nWHERE stage = 'Benefits Issued');\n\n#B8. Which caseworker has the most applications assigned to them?\nSELECT assigned_to, COUNT(DISTINCT application_id) as num_app\nFROM benefits_applications\nGROUP BY assigned_to\nORDER BY num_app DESC\nLIMIT 1;\n\n#B9. Show the count of applications at each stage broken down by priority level — all in one query.\nSELECT\n    priority,\n    COUNT(DISTINCT application_id) as total_app,\n    SUM(CASE WHEN stage = 'Intake' then 1 else 0 END) as st_intake,\n    SUM(CASE WHEN stage = 'Eligibility Review' then 1 else 0 END) as st_elig_rev,\n    SUM(CASE WHEN stage = 'Document Verification' then 1 else 0 END) as st_doc_verif,\n    SUM(CASE WHEN stage = 'Approval' then 1 else 0 END) as st_approval,\n    SUM(CASE WHEN stage = 'Benefits Issued' then 1 else 0 END) as st_benef_issued\nFROM benefits_applications\nGROUP BY priority;\n\n#B10. What percentage of applications were approved vs denied? Show side by side.\nSELECT\n    COUNT(DISTINCT application_id) AS total_app,\n    ROUND(SUM(CASE WHEN status = 'Approved' THEN 1 ELSE 0 END) * 100 / COUNT(*), 1) AS num_approved,\n    ROUND(SUM(CASE WHEN status = 'Denied' THEN 1 ELSE 0 END) * 100 / COUNT(*), 1) AS num_denied\nFROM benefits_applications\nWHERE stage = 'Approval';\n\n#B11. Which applicant type has the highest denial rate?\nSELECT applicant_type, COUNT(application_id) as total_cases,\nROUND(SUM(CASE WHEN status = 'Denied' then 1 else 0 END) / COUNT(*) * 100, 1) as denied_rate\nFROM benefits_applications\nWHERE stage = 'Approval'\nGROUP BY applicant_type\nORDER BY denied_rate DESC\nLIMIT 1;\n\n#B12. Which stage has the most applications stuck right now? struggling here\nSELECT stage, COUNT(*) AS stuck_apps\nFROM (\n    SELECT ba.application_id, ba.stage\n    FROM benefits_applications ba\n    INNER JOIN (\n        SELECT application_id, MAX(entered_at) AS last_event\n        FROM benefits_applications\n        GROUP BY application_id\n    ) latest ON ba.application_id = latest.application_id\n           AND ba.entered_at = latest.last_event\n    WHERE ba.stage != 'Benefits Issued'\n) AS stuck\nGROUP BY stage\nORDER BY stuck_apps DESC\nLIMIT 1;\n\n#B13. Are Critical priority cases actually being processed faster than Standard ones? Show average days per stage for each priority level.\nWITH stage_with_prev AS (\n    SELECT application_id, stage, priority, entered_at,\n           LAG(entered_at) OVER (PARTITION BY application_id ORDER BY entered_at) AS prev_entered_at\n    FROM benefits_applications\n),\ndays_spent AS (\n    SELECT stage, priority, DATEDIFF(entered_at, prev_entered_at) AS days_spent\n    FROM stage_with_prev\n    WHERE prev_entered_at IS NOT NULL\n)\nSELECT priority, stage, ROUND(AVG(days_spent), 1) AS avg_days\nFROM days_spent\nGROUP BY priority, stage\nORDER BY stage, avg_days ASC;\n\n#B14. Build the full pipeline health summary like M8 — for each stage show total applications, stuck count, average days, \n#and whether it's over or under target.\nWITH total_cases AS (\n    SELECT stage, COUNT(DISTINCT application_id) AS total_cases\n    FROM benefits_applications\n    GROUP BY stage\n),\nstuck_count AS (\n    SELECT stage, COUNT(*) AS stuck_apps\n    FROM (\n        SELECT ba.application_id, ba.stage\n        FROM benefits_applications ba\n        INNER JOIN (\n            SELECT application_id, MAX(entered_at) AS last_event\n            FROM benefits_applications\n            GROUP BY application_id\n        ) latest ON ba.application_id = latest.application_id\n               AND ba.entered_at = latest.last_event\n        WHERE ba.stage != 'Benefits Issued'\n    ) AS stuck\n    GROUP BY stage\n),\nstage_with_prev AS (\n    SELECT application_id, stage, entered_at,\n           LAG(entered_at) OVER (PARTITION BY application_id ORDER BY entered_at) AS prev_entered_at\n    FROM benefits_applications\n),\ndays_spent AS (\n    SELECT stage, DATEDIFF(entered_at, prev_entered_at) AS days_spent\n    FROM stage_with_prev\n    WHERE prev_entered_at IS NOT NULL\n),\navg_days AS (\n    SELECT stage, ROUND(AVG(days_spent), 1) AS avg_days\n    FROM days_spent\n    GROUP BY stage\n)\n-- final SELECT goes here\nSELECT tc.stage, tc.total_cases, COALESCE(sc.stuck_apps, 0), ad.avg_days, atb.target_days,\n    CASE WHEN ad.avg_days > atb.target_days then 'Over' else 'On track' END as stage_status\nFROM total_cases tc\nLEFT JOIN stuck_count sc ON tc.stage = sc.stage\nLEFT JOIN avg_days ad ON tc.stage = ad.stage\nLEFT JOIN stage_targets_benefits atb on tc.stage = atb.stage;\n\n\n",
