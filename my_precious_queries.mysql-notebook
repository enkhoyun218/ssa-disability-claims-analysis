    "content": "\\about\n\n-- ============================================================\n-- CASE PIPELINE PRACTICE QUERIES\n-- Database: case_pipeline\n-- ============================================================\n\nUSE case_pipeline;\n\n-- ============================================================\n-- LEVEL 1: GET FAMILIAR WITH THE DATA\n-- ============================================================\nSELECT *\nFROM case_events;\n\n-- Q1. How many total events are in the table?\nSELECT COUNT(*) AS num_events\nFROM case_events;\n\n-- Q2. What are all the unique stages a case can be in?\nSELECT DISTINCT stage\nFROM case_events;\n\n-- Q3. How many unique cases exist in the dataset?\nSELECT COUNT(DISTINCT case_id) AS num_unique_cases\nFROM case_events;\n\n-- Q4. Show all the different case types and how many cases belong to each one.\nSELECT case_type, COUNT(*) AS cases_in_diff_stages\nFROM case_events\nGROUP BY case_type\nORDER BY cases_in_diff_stages DESC;\n\n-- Q5. Show all events for case_id = 1 ordered by entered_at.\nSELECT * FROM case_events\nWHERE case_id = 1\nORDER BY entered_at ASC;\n\n\n-- ============================================================\n-- LEVEL 2: FILTERING & GROUPING\n-- ============================================================\n\n-- Q6. How many cases are of type Permit?\nSELECT COUNT(DISTINCT case_id) AS num_permit\nFROM case_events\nWHERE case_type = 'Permit';\n\n-- Q7. Show all cases that entered the Verification stage.\nSELECT * FROM case_events\nWHERE stage = 'Verification';\n\n-- Q8. How many cases reached the Closed stage?\nSELECT COUNT(DISTINCT case_id) AS num_closed\nFROM case_events\nWHERE stage = 'Closed';\n\n-- Q9. How many cases never reached Closed?\nSELECT COUNT(DISTINCT case_id) AS never_closed\nFROM case_events\nWHERE case_id NOT IN (\n    SELECT case_id FROM case_events WHERE stage = 'Closed'\n);\n\n-- Q10. Which assigned person has the most events assigned to them?\nSELECT assigned_to, COUNT(*) AS num_events\nFROM case_events\nGROUP BY assigned_to\nORDER BY num_events DESC\nLIMIT 1;\n\n\n-- ============================================================\n-- LEVEL 3: TIME & BOTTLENECKS\n-- ============================================================\n\n-- Q11. What is the earliest and latest entered_at date in the whole dataset?\nSELECT MIN(entered_at) AS earliest_date,\n       MAX(entered_at) AS latest_date\nFROM case_events;\n\n-- Q12. How many cases entered Verification in the last 3 months?\nSELECT COUNT(DISTINCT case_id) AS num_verif_3_months\nFROM case_events\nWHERE stage = 'Verification'\n  AND entered_at >= NOW() - INTERVAL 3 MONTH;\n\n-- Q13. Which stage has the most cases currently sitting in it?\nSELECT stage, COUNT(*) AS cases_in_stage\nFROM case_events\nGROUP BY stage\nORDER BY cases_in_stage DESC\nLIMIT 1;\n\n-- Q14. Show all cases that have been in Review stage for more than 20 days.\nSELECT case_id, MAX(entered_at) AS last_seen\nFROM case_events\nWHERE stage = 'Review'\nGROUP BY case_id\nHAVING last_seen < NOW() - INTERVAL 20 DAY;\n\n\n-- ============================================================\n-- LEVEL 4: PROCESS IMPROVEMENT INSIGHTS\n-- ============================================================\n\n-- Q15. For each case type, how many made it to Closed vs how many didn't?\nSELECT\n    case_type,\n    SUM(CASE WHEN stage = 'Closed' THEN 1 ELSE 0 END) AS reached_closed,\n    SUM(CASE WHEN stage != 'Closed' THEN 1 ELSE 0 END) AS did_not_close\nFROM case_events\nGROUP BY case_type;\n\n-- Q16. Which case type has the highest drop-off rate?\nSELECT case_type, COUNT(*) AS unclosed_cases\nFROM (\n    SELECT case_id, case_type\n    FROM case_events\n    GROUP BY case_id, case_type\n    HAVING SUM(CASE WHEN stage = 'Closed' THEN 1 ELSE 0 END) = 0\n) AS unclosed\nGROUP BY case_type\nORDER BY unclosed_cases DESC\nLIMIT 1;\n\n-- Q17. How many cases are stuck at each stage?\nSELECT stage, COUNT(*) AS stuck_cases\nFROM (\n    SELECT ce.case_id, ce.stage\n    FROM case_events ce\n    INNER JOIN (\n        SELECT case_id, MAX(entered_at) AS last_event\n        FROM case_events\n        GROUP BY case_id\n    ) latest ON ce.case_id = latest.case_id\n           AND ce.entered_at = latest.last_event\n    WHERE ce.stage != 'Closed'\n) AS stuck\nGROUP BY stage\nORDER BY stuck_cases DESC;\n\n\n-- ============================================================\n-- SET A: WORKLOAD & ASSIGNMENT ANALYSIS\n-- ============================================================\n\n-- A1. How many cases is each staff member currently handling (not closed)?\nSELECT assigned_to,\n       COUNT(DISTINCT case_id) AS open_cases\nFROM case_events\nWHERE case_id NOT IN (\n    SELECT case_id FROM case_events WHERE stage = 'Closed'\n)\nGROUP BY assigned_to\nORDER BY open_cases DESC;\n\n-- A2. Which staff member has the highest number of stalled cases?\nSELECT assigned_to,\n       COUNT(DISTINCT case_id) AS open_cases\nFROM case_events\nWHERE case_id NOT IN (\n    SELECT case_id FROM case_events WHERE stage = 'Closed'\n)\nGROUP BY assigned_to\nORDER BY open_cases DESC\nLIMIT 1;\n\n-- A3. Staff member case type distribution.\nSELECT assigned_to, case_type, COUNT(DISTINCT case_id) AS case_count\nFROM case_events\nGROUP BY assigned_to, case_type\nHAVING case_count > 10\nORDER BY assigned_to, case_count DESC;\n\n-- A4. How many total cases has each staff member ever handled?\nSELECT assigned_to,\n       COUNT(DISTINCT case_id) AS cases\nFROM case_events\nGROUP BY assigned_to\nORDER BY cases DESC;\n\n-- A5. Which staff member has the best closure rate?\nSELECT assigned_to,\n       ROUND(COUNT(DISTINCT CASE\n           WHEN stage = 'Closed' THEN case_id\n       END) * 100.0\n       / COUNT(DISTINCT case_id), 1) AS closure_rate_pct\nFROM case_events\nGROUP BY assigned_to\nORDER BY closure_rate_pct DESC\nLIMIT 1;\n\n-- A6. Cases assigned to more than one person across stages.\nSELECT case_id, COUNT(DISTINCT assigned_to) AS num_people_assigned\nFROM case_events\nGROUP BY case_id\nHAVING COUNT(DISTINCT assigned_to) > 1;\n\n-- A7. Staff member with oldest open case.\nSELECT assigned_to, MIN(entered_at) AS oldest_open_case\nFROM case_events\nWHERE case_id NOT IN (\n    SELECT case_id FROM case_events WHERE stage = 'Closed'\n)\nGROUP BY assigned_to\nORDER BY MIN(entered_at) ASC\nLIMIT 1;\n\n-- A8. Full staff leaderboard.\nSELECT\n    assigned_to,\n    COUNT(DISTINCT case_id) AS total_cases,\n    COUNT(DISTINCT CASE WHEN stage = 'Closed' THEN case_id END) AS cases_closed,\n    COUNT(DISTINCT CASE WHEN stage != 'Closed' THEN case_id END) AS cases_open,\n    ROUND(COUNT(DISTINCT CASE WHEN stage = 'Closed' THEN case_id END)\n        * 100.0 / COUNT(DISTINCT case_id), 1) AS closure_rate_pct\nFROM case_events\nGROUP BY assigned_to\nORDER BY closure_rate_pct DESC;\n\n\n-- ============================================================\n-- DISTINCT PRACTICE\n-- ============================================================\n\n-- D1. All unique case types.\nSELECT DISTINCT case_type FROM case_events;\n\n-- D2. How many unique people are assigned?\nSELECT COUNT(DISTINCT assigned_to) AS unique_staff FROM case_events;\n\n-- D3. How many unique stages exist per case type?\nSELECT case_type, COUNT(DISTINCT stage) AS unique_stages\nFROM case_events\nGROUP BY case_type;\n\n\n-- ============================================================\n-- CASE WHEN PRACTICE\n-- ============================================================\n\n-- C1. Add a priority column.\nSELECT id, case_id, case_type, stage, entered_at, assigned_to,\n    CASE WHEN case_type = 'Appeal' THEN 'High'\n         WHEN case_type = 'Complaint' THEN 'Medium'\n         ELSE 'Normal'\n    END AS priority\nFROM case_events;\n\n-- C2. Add an is_closed column.\nSELECT id, case_id, case_type, stage, entered_at, assigned_to,\n    CASE WHEN stage = 'Closed' THEN 1\n         ELSE 0\n    END AS is_closed\nFROM case_events;\n\n-- C3. Count high, medium, and normal priority cases side by side.\nSELECT\n    SUM(CASE WHEN case_type = 'Appeal' THEN 1 ELSE 0 END) AS appeal_cases,\n    SUM(CASE WHEN case_type = 'Complaint' THEN 1 ELSE 0 END) AS complaint_cases,\n    SUM(CASE WHEN case_type NOT IN ('Complaint', 'Appeal') THEN 1 ELSE 0 END) AS other_cases\nFROM case_events;\n\n\n-- ============================================================\n-- SET S: SUBQUERY PRACTICE\n-- ============================================================\n\n-- S1. Cases that passed through more than 3 stages.\nSELECT *\nFROM case_events\nWHERE case_id IN (\n    SELECT case_id\n    FROM case_events\n    GROUP BY case_id\n    HAVING COUNT(DISTINCT stage) > 3\n);\n\n-- S2. All events assigned to the person with the most Permit cases.\nSELECT *\nFROM case_events\nWHERE assigned_to = (\n    SELECT assigned_to\n    FROM case_events\n    GROUP BY assigned_to\n    ORDER BY SUM(CASE WHEN case_type = 'Permit' THEN 1 ELSE 0 END) DESC\n    LIMIT 1\n);\n\n-- S3. Cases that started after the average Intake date.\nSELECT *\nFROM case_events\nWHERE entered_at > (\n    SELECT FROM_UNIXTIME(AVG(UNIX_TIMESTAMP(entered_at)))\n    FROM case_events\n    WHERE stage = 'Intake'\n);\n\n-- S4. Staff members who handle only one type of case.\nSELECT assigned_to, COUNT(DISTINCT case_type) AS num_case_types\nFROM case_events\nGROUP BY assigned_to\nHAVING COUNT(DISTINCT case_type) = 1;\n\n\n-- ============================================================\n-- SET W: CASE WHEN INSIDE AGGREGATES\n-- ============================================================\n\n-- W1. Cases entered per stage in last 30 days vs older than 30 days.\nSELECT\n    stage,\n    SUM(CASE WHEN entered_at >= NOW() - INTERVAL 30 DAY THEN 1 ELSE 0 END) AS last_30_days,\n    SUM(CASE WHEN entered_at < NOW() - INTERVAL 30 DAY THEN 1 ELSE 0 END) AS older_than_30_days\nFROM case_events\nGROUP BY stage;\n\n-- W2. Per staff member, count of each case type as separate columns.\nSELECT\n    assigned_to,\n    SUM(CASE WHEN case_type = 'Appeal' THEN 1 ELSE 0 END) AS appeal_cases,\n    SUM(CASE WHEN case_type = 'Permit' THEN 1 ELSE 0 END) AS permit_cases,\n    SUM(CASE WHEN case_type = 'Benefits' THEN 1 ELSE 0 END) AS benefits_cases,\n    SUM(CASE WHEN case_type = 'License' THEN 1 ELSE 0 END) AS license_cases,\n    SUM(CASE WHEN case_type = 'Complaint' THEN 1 ELSE 0 END) AS complaint_cases\nFROM case_events\nGROUP BY assigned_to;\n\n-- W3. Per case type, early vs late vs closed stage counts.\nSELECT\n    case_type,\n    SUM(CASE WHEN stage IN ('Intake', 'Review') THEN 1 ELSE 0 END) AS early_stage,\n    SUM(CASE WHEN stage IN ('Verification', 'Approval') THEN 1 ELSE 0 END) AS late_stage,\n    SUM(CASE WHEN stage = 'Closed' THEN 1 ELSE 0 END) AS closed\nFROM case_events\nGROUP BY case_type;\n\n\n-- ============================================================\n-- SET H: WHERE VS HAVING\n-- ============================================================\n\n-- H1. Staff with more than 5 Appeal cases.\nSELECT assigned_to, COUNT(DISTINCT case_id) AS appeal_cases\nFROM case_events\nWHERE case_type = 'Appeal'\nGROUP BY assigned_to\nHAVING COUNT(DISTINCT case_id) > 5;\n\n-- H2. Case types where average stages per case is less than 4.\nSELECT case_type, AVG(num_stages) AS avg_stages\nFROM (\n    SELECT case_id, case_type, COUNT(DISTINCT stage) AS num_stages\n    FROM case_events\n    GROUP BY case_id, case_type\n) AS case_stage_counts\nGROUP BY case_type\nHAVING AVG(num_stages) < 4;\n\n-- H3. Staff with cases stuck at every non-closed stage.\nSELECT assigned_to, COUNT(DISTINCT stage) AS stages_covered\nFROM case_events\nWHERE stage != 'Closed'\nGROUP BY assigned_to\nHAVING COUNT(DISTINCT stage) = 4;\n\n\n-- ============================================================\n-- SET D: JOINS\n-- ============================================================\n\n-- D1. Each stage alongside its target days.\nSELECT ce.stage, st.target_days\nFROM case_events ce\nINNER JOIN stage_targets st ON ce.stage = st.stage;\n\n-- D2. Each case event with target days next to it.\nSELECT ce.*, st.target_days\nFROM case_events ce\nINNER JOIN stage_targets st ON ce.stage = st.stage;\n\n-- D3. Stages exceeding their target days on average.\nWITH stage_with_prev AS (\n    SELECT case_id, stage, entered_at,\n           LAG(entered_at) OVER (PARTITION BY case_id ORDER BY entered_at) AS prev_entered_at\n    FROM case_events\n),\ndays_spent AS (\n    SELECT stage, DATEDIFF(entered_at, prev_entered_at) AS days_spent\n    FROM stage_with_prev\n    WHERE prev_entered_at IS NOT NULL\n)\nSELECT d.stage, ROUND(AVG(days_spent), 1) AS avg_days, st.target_days\nFROM days_spent d\nJOIN stage_targets st ON d.stage = st.stage\nGROUP BY d.stage, st.target_days\nHAVING AVG(days_spent) > st.target_days;\n\n\n-- ============================================================\n-- SET E: CTEs\n-- ============================================================\n\n-- E1. Cases with more than 3 stages using a CTE.\nWITH more_than_3_stages AS (\n    SELECT case_id\n    FROM case_events\n    GROUP BY case_id\n    HAVING COUNT(DISTINCT stage) > 3\n)\nSELECT *\nFROM case_events\nWHERE case_id IN (SELECT case_id FROM more_than_3_stages);\n\n-- E2. Staff below average closure rate.\nWITH emp_closure_rate AS (\n    SELECT assigned_to,\n           COUNT(DISTINCT CASE WHEN stage = 'Closed' THEN case_id END) * 100.0\n           / COUNT(DISTINCT case_id) AS closure_rate\n    FROM case_events\n    GROUP BY assigned_to\n)\nSELECT assigned_to, ROUND(closure_rate, 1) AS closure_rate\nFROM emp_closure_rate\nWHERE closure_rate < (SELECT AVG(closure_rate) FROM emp_closure_rate);\n\n-- E3. Oldest open case per case type.\nWITH open_cases AS (\n    SELECT case_type, MIN(entered_at) AS oldest_open_case\n    FROM case_events\n    WHERE case_id NOT IN (\n        SELECT case_id FROM case_events WHERE stage = 'Closed'\n    )\n    GROUP BY case_type\n)\nSELECT case_type, oldest_open_case\nFROM open_cases\nORDER BY oldest_open_case ASC;\n\n\n-- ============================================================\n-- SET F: WINDOW FUNCTIONS\n-- ============================================================\n\n-- F1. Number each stage a case went through in order.\nSELECT\n    case_id,\n    stage,\n    entered_at,\n    ROW_NUMBER() OVER (PARTITION BY case_id ORDER BY entered_at) AS stage_number\nFROM case_events\nORDER BY case_id, entered_at;\n\n-- F2. Current stage and previous stage side by side.\nSELECT case_id, stage, entered_at,\n    LAG(stage) OVER (PARTITION BY case_id ORDER BY entered_at) AS previous_stage\nFROM case_events;\n\n-- F3. Days passed between each stage transition.\nSELECT case_id, stage, entered_at,\n    DATEDIFF(entered_at, LAG(entered_at) OVER (PARTITION BY case_id ORDER BY entered_at)) AS days_since_last_stage\nFROM case_events;\n\n-- F4. Rank staff members by closure rate.\nWITH closure_rates AS (\n    SELECT assigned_to,\n           COUNT(DISTINCT CASE WHEN stage = 'Closed' THEN case_id END) * 100.0\n           / COUNT(DISTINCT case_id) AS closure_rate\n    FROM case_events\n    GROUP BY assigned_to\n)\nSELECT assigned_to,\n       ROUND(closure_rate, 1) AS closure_rate,\n       RANK() OVER (ORDER BY closure_rate DESC) AS ranking\nFROM closure_rates;\n\n\n-- ============================================================\n-- MIXED SET M: COMBINED CHALLENGES\n-- ============================================================\n\n-- M1. Staff with above average case load (open cases only).\nWITH open_cases AS (\n    SELECT case_id\n    FROM case_events\n    WHERE case_id NOT IN (\n        SELECT case_id FROM case_events WHERE stage = 'Closed'\n    )\n),\nstaff_load AS (\n    SELECT assigned_to, COUNT(DISTINCT ce.case_id) AS case_load\n    FROM case_events ce\n    WHERE ce.case_id IN (SELECT case_id FROM open_cases)\n    GROUP BY assigned_to\n)\nSELECT assigned_to, case_load\nFROM staff_load\nWHERE case_load > (SELECT AVG(case_load) FROM staff_load)\nORDER BY case_load DESC;\n\n-- M2. Per case type: total, completed within 30 days, took longer, still open.\nWITH case_duration AS (\n    SELECT\n        case_id,\n        case_type,\n        DATEDIFF(MAX(entered_at), MIN(entered_at)) AS days_to_complete,\n        MAX(CASE WHEN stage = 'Closed' THEN 1 ELSE 0 END) AS is_closed\n    FROM case_events\n    GROUP BY case_id, case_type\n)\nSELECT\n    case_type,\n    COUNT(*) AS total_cases,\n    SUM(CASE WHEN is_closed = 1 AND days_to_complete <= 30 THEN 1 ELSE 0 END) AS completed_within_30,\n    SUM(CASE WHEN is_closed = 1 AND days_to_complete > 30 THEN 1 ELSE 0 END) AS took_longer_than_30,\n    SUM(CASE WHEN is_closed = 0 THEN 1 ELSE 0 END) AS still_open\nFROM case_duration\nGROUP BY case_type;\n\n-- M3. Top 3 most overloaded stages with target days.\nWITH overload_types AS (\n    SELECT stage, COUNT(case_id) AS open_cases\n    FROM case_events\n    WHERE case_id NOT IN (SELECT case_id FROM case_events WHERE stage = 'Closed')\n    GROUP BY stage\n)\nSELECT overload_types.stage, overload_types.open_cases, stage_targets.target_days\nFROM overload_types\nINNER JOIN stage_targets ON overload_types.stage = stage_targets.stage\nORDER BY open_cases DESC\nLIMIT 3;\n\n-- M4. Monthly new cases opened vs closed.\nWITH monthly_counts AS (\n    SELECT\n        DATE_FORMAT(entered_at, '%Y-%m') AS month,\n        SUM(CASE WHEN stage = 'Intake' THEN 1 ELSE 0 END) AS new_cases,\n        SUM(CASE WHEN stage = 'Closed' THEN 1 ELSE 0 END) AS closed_cases\n    FROM case_events\n    GROUP BY DATE_FORMAT(entered_at, '%Y-%m')\n)\nSELECT\n    month,\n    new_cases,\n    closed_cases,\n    new_cases - closed_cases AS case_diff\nFROM monthly_counts\nORDER BY month ASC;\n\n-- M5. Staff with cases stuck at Verification 15+ days AND closure rate below 50%.\nWITH stuck_in_verification AS (\n    SELECT assigned_to, COUNT(DISTINCT case_id) AS stuck_cases\n    FROM case_events c\n    WHERE stage = 'Verification'\n      AND entered_at = (SELECT MAX(entered_at) FROM case_events WHERE case_id = c.case_id)\n      AND entered_at < NOW() - INTERVAL 15 DAY\n      AND case_id NOT IN (\n          SELECT case_id FROM case_events WHERE stage IN ('Approval', 'Closed')\n      )\n    GROUP BY assigned_to\n),\nclosure_rates AS (\n    SELECT assigned_to,\n           COUNT(DISTINCT CASE WHEN stage = 'Closed' THEN case_id END) * 100.0\n           / COUNT(DISTINCT case_id) AS closure_rate\n    FROM case_events\n    GROUP BY assigned_to\n)\nSELECT cr.assigned_to,\n       ROUND(cr.closure_rate, 1) AS closure_rate,\n       sv.stuck_cases\nFROM closure_rates cr\nINNER JOIN stuck_in_verification sv ON cr.assigned_to = sv.assigned_to\nWHERE cr.closure_rate < 50\nORDER BY sv.stuck_cases DESC;\n\n-- M6. Case types ranked by drop-off rate.\nWITH open_cases_list AS (\n    SELECT case_type,\n        SUM(CASE WHEN case_id NOT IN (SELECT case_id FROM case_events WHERE stage = 'Closed') THEN 1 ELSE 0 END) AS drop_off_count\n    FROM case_events\n    GROUP BY case_type\n),\ntotal_cases_list AS (\n    SELECT case_type, COUNT(DISTINCT case_id) AS total_cases\n    FROM case_events\n    GROUP BY case_type\n)\nSELECT\n    ocl.case_type,\n    drop_off_count,\n    total_cases,\n    ROUND(drop_off_count / total_cases * 100.0, 1) AS drop_off_rate,\n    RANK() OVER (ORDER BY drop_off_count / total_cases DESC) AS rank_worst\nFROM open_cases_list ocl\nINNER JOIN total_cases_list tcl ON ocl.case_type = tcl.case_type\nORDER BY drop_off_rate DESC;\n\n-- M8. Full pipeline health dashboard.\nWITH total_cases_passed AS (\n    SELECT stage, COUNT(DISTINCT case_id) AS total_cases\n    FROM case_events\n    GROUP BY stage\n),\ncases_stuck AS (\n    SELECT stage, COUNT(*) AS stuck_cases\n    FROM (\n        SELECT ce.case_id, ce.stage\n        FROM case_events ce\n        INNER JOIN (\n            SELECT case_id, MAX(entered_at) AS last_event\n            FROM case_events\n            GROUP BY case_id\n        ) latest ON ce.case_id = latest.case_id\n               AND ce.entered_at = latest.last_event\n        WHERE ce.stage != 'Closed'\n    ) AS stuck_cases\n    GROUP BY stage\n),\navg_days_per_stage AS (\n    SELECT s.stage, ROUND(AVG(days_spent), 1) AS avg_days_spent, st.target_days\n    FROM (\n        SELECT stage,\n               DATEDIFF(entered_at, prev_entered_at) AS days_spent\n        FROM (\n            SELECT case_id, stage, entered_at,\n                   LAG(entered_at) OVER (PARTITION BY case_id ORDER BY entered_at) AS prev_entered_at\n            FROM case_events\n        ) AS stage_with_prev\n        WHERE prev_entered_at IS NOT NULL\n    ) s\n    JOIN stage_targets st ON s.stage = st.stage\n    GROUP BY s.stage, st.target_days\n)\nSELECT\n    tcp.stage,\n    tcp.total_cases,\n    COALESCE(cs.stuck_cases, 0) AS stuck_cases,\n    adps.avg_days_spent,\n    adps.target_days,\n    CASE WHEN adps.avg_days_spent > adps.target_days THEN 'Over' ELSE 'On Track' END AS status\nFROM total_cases_passed tcp\nLEFT JOIN cases_stuck cs ON tcp.stage = cs.stage\nLEFT JOIN avg_days_per_stage adps ON tcp.stage = adps.stage;\n\n-- M9. Find all cases where the same person handled every single stage \n-- from Intake to whatever stage the case is currently at — meaning no handoffs happened.\nSELECT case_id,\n    MIN(assigned_to) as handled_by,\n    COUNT(DISTINCT assigned_to) AS num_people\nFROM case_events\nGROUP BY case_id \nHAVING COUNT(DISTINCT assigned_to) = 1;\n\n-- M10. Using CTEs, write a query that identifies the single biggest bottleneck in the entire pipeline — the one stage \n-- that has the worst combination of high stuck cases AND exceeds its target days the most. \n-- Return just that one stage and why it qualifies.\n\nWITH total_cases_passed AS (\n    SELECT stage, COUNT(DISTINCT case_id) AS total_cases\n    FROM case_events\n    GROUP BY stage\n),\ncases_stuck AS (\n    SELECT stage, COUNT(*) AS stuck_cases\n    FROM (\n        SELECT ce.case_id, ce.stage\n        FROM case_events ce\n        INNER JOIN (\n            SELECT case_id, MAX(entered_at) AS last_event\n            FROM case_events\n            GROUP BY case_id\n        ) latest ON ce.case_id = latest.case_id\n               AND ce.entered_at = latest.last_event\n        WHERE ce.stage != 'Closed'\n    ) AS stuck_cases\n    GROUP BY stage\n),\navg_days_per_stage AS (\n    SELECT s.stage, ROUND(AVG(days_spent), 1) AS avg_days_spent, st.target_days\n    FROM (\n        SELECT stage,\n               DATEDIFF(entered_at, prev_entered_at) AS days_spent\n        FROM (\n            SELECT case_id, stage, entered_at,\n                   LAG(entered_at) OVER (PARTITION BY case_id ORDER BY entered_at) AS prev_entered_at\n            FROM case_events\n        ) AS stage_with_prev\n        WHERE prev_entered_at IS NOT NULL\n    ) s\n    JOIN stage_targets st ON s.stage = st.stage\n    GROUP BY s.stage, st.target_days\n)\nSELECT\n    tcp.stage,\n    tcp.total_cases,\n    COALESCE(cs.stuck_cases, 0) AS stuck_cases,\n    adps.avg_days_spent,\n    adps.target_days\nFROM total_cases_passed tcp\nLEFT JOIN cases_stuck cs ON tcp.stage = cs.stage\nLEFT JOIN avg_days_per_stage adps ON tcp.stage = adps.stage\nORDER BY (stuck_cases + (adps.avg_days_spent - adps.target_days)) DESC\nLIMIT 1;\n\n",
